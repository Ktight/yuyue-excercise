{
  "name": "yu-yue-lian",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx,.mjs",
    "lint:fix": "eslint . --ext .vue,.ts,.tsx,.mjs --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,css}\"",
    "typecheck": "vue-tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "generate:api-types": "node scripts/generate-api-types.mjs",
    "generate:enums": "node scripts/generate-enums.mjs",
    "generate": "npm run generate:api-types && npm run generate:enums",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:all": "npm run typecheck && npm run lint && prettier --check \"src/**/*.{vue,ts,tsx,css}\" && npm run check:boundaries && npm run test && npm run build"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "pinia": "^4.0.2",
    "vant": "^4.10.0",
    "vue": "^3.5.39",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.10.0",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5",
    "yaml": "^2.9.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "overrides": {
    "js-yaml": "^4.3.0"
  }
}
